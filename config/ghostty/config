theme = light:Gruvbox Light,dark:Catppuccin Mocha
# theme = light:Monokai Pro Light,dark:Everforest Dark Hard
# theme = light:Rose Pine Dawn,dark:Everforest Dark Hard
# theme = light:Violet Light,dark:Kanagawa Wave
# theme = light:Catppuccin Latte,dark:Dracula+
# theme = light:TokyoNight Day,dark:TokyoNight Moon
# theme = light:Catppuccin Latte,dark:TokyoNight Moon

font-size = 14
background = #080807
background-opacity = 1
background-image = assets/black-paper-full.jpg
background-image-fit = cover
background-image-position = center
background-image-repeat = false
background-image-opacity = 0.22
cursor-style = block
cursor-color = #a7c080
shell-integration-features = no-cursor
# tabs, hidden, native, transparent
macos-titlebar-style = hidden

unfocused-split-opacity = 0.85

window-decoration = false
macos-window-shadow = false

window-padding-balance = true
window-padding-x = 10
window-padding-y = 10

keybind = global:cmd+e=toggle_quick_terminal
keybind = cmd+grave_accent=toggle_quick_terminal
keybind = cmd+r=reload_config

